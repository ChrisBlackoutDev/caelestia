{
    "general": {
        "idle": {
            "timeouts": [
                {
                    "idleAction": "lock",
                    "timeout": 1800
                },
                {
                    "idleAction": "dpms off",
                    "returnAction": "dpms on",
                    "timeout": 2100
                },
                {
                    "idleAction": [
                        "systemctl",
                        "suspend-then-hibernate"
                    ],
                    "timeout": 3600
                }
            ]
        }
    }
}
